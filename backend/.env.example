# Environment Variables — copy this file to .env and fill in your values
# Never commit .env to version control

# ── Database / Supabase ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
# Set DB_SSL=true when connecting to Supabase cloud
DB_SSL=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
